# Spark cloud config — copy this file to `.env` and fill in your Supabase values.
# `.env` is gitignored; `.env.example` is the committed template (no real secrets).
#
# Get these from Supabase → Project Settings → API:
SPARK_SUPABASE_URL=https://<project-ref>.supabase.co
SPARK_SUPABASE_KEY=<anon-public-key>

# Your team's room code (the join secret):
SPARK_ROOM=TEAM-HACK

# Optional — author of your cards. Leave unset to auto-detect:
# GitHub handle (gh CLI) → git user.name → OS user. Uncomment only to override.
#SPARK_AGENT=yourname
